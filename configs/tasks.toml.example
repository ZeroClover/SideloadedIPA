# Signing tasks configuration (TOML)
# Define one or more signing tasks using the [[tasks]] array.

# ========================================
# Publishing model (serverless)
# ========================================
# After each resign the pipeline:
#   1. reads the signed IPA's ACTUAL bundle id + version,
#   2. uploads the IPA to Cloudflare R2 under a versioned key:
#        apps/<slug>/<version>/<App>.ipa   (immutable cache headers)
#   3. merges the result into the site/apps.json registry on R2 — the single
#      data source the Vercel-hosted download page and itms.plist route read,
#   4. triggers Vercel on-demand revalidation and deletes stale versioned keys.
#
# Bucket, account id and public base URL come from environment variables
# (R2_* secrets/vars), never from this file. The optional [r2] table only
# tweaks the object layout; defaults are shown below.
# [r2]
# key_prefix = "apps"              # object key prefix for IPAs and icons
# apps_json_key = "site/apps.json" # registry key consumed by the Vercel front-end

# ========================================
# Option 1: Direct IPA URL (Legacy)
# ========================================
# Tasks with ipa_url will always rebuild on every run.
# No version tracking or caching.

[[tasks]]
# Identifier used to look up the provisioning profile and output files
task_name = "MyApp"

# Human-friendly app name; used for profile naming (e.g., "MyApp Dev")
app_name = "MyApp"

# Bundle identifier of the app (required for provisioning profile creation)
# This must match an existing Bundle ID in your Apple Developer account
bundle_id = "com.example.myapp"

# Direct download URL of the original IPA to sign
ipa_url = "https://example.com/path/to/MyApp.ipa"

# Optional: stable key for R2 object paths and the apps.json registry /
# download-page URLs. Defaults to a slugified app_name ("MyApp" here).
# slug = "myapp"

# Optional: card icon source. An ipa_url task has no repository to read from,
# so it needs either an absolute URL or "ipa:" (pull it out of the signed IPA).
# icon_path = "ipa:"

# ========================================
# Option 2: GitHub Release Tracking (New, with Caching)
# ========================================
# Tasks with repo_url will track GitHub releases and only rebuild
# when the release version or timestamp changes.

[[tasks]]
task_name = "AnotherApp"
app_name = "Another App"
bundle_id = "com.example.anotherapp"

# GitHub repository URL (mutually exclusive with ipa_url)
repo_url = "https://github.com/owner/repo"

# Glob pattern to match release assets (optional, default: "*.ipa")
# Uses Python fnmatch syntax
release_glob = "*.ipa"

# Whether to use prerelease versions (optional, default: false)
# If true: fetches latest prerelease, falls back to stable if none exist
# If false: fetches only latest stable release
use_prerelease = false

# Explicit slug needed when the slugified app name ("Another_App") is not the
# desired public key.
slug = "anotherapp"

# Optional: card icon source — a path inside repo_url (fetched at the release
# tag), an absolute URL, or "ipa:". Nothing is inferred: Flutter projects keep
# the master under ios/Runner/Assets.xcassets/, native projects use their own
# names and directories. Any raster format is accepted (detected by magic bytes,
# not extension) and normalised to a square PNG of at most 512x512. Use a
# SQUARE, full-bleed master — the page rounds corners in CSS, so a pre-rounded
# source double-rounds. Omit to leave the existing icon untouched.
icon_path = "ios/Runner/Assets.xcassets/AppIcon.appiconset/Icon-App-1024x1024@1x.png"

# ========================================
# Example: Tracking a Specific Asset Pattern
# ========================================
[[tasks]]
task_name = "SpecialApp"
app_name = "Special App"
bundle_id = "com.example.specialapp"
repo_url = "https://github.com/specialorg/specialapp"

# Match only assets with "universal" in the filename
release_glob = "*universal*.ipa"

# Use prerelease versions for beta testing
use_prerelease = true

slug = "specialapp"

# ========================================
# Multi-bundle signing (standard LiveContainer example)
# ========================================
# A release with more than one IPA asset needs an exact selector. The standard
# build has four profile-bearing bundles. The SideStore build is intentionally
# a separate policy: it adds LiveWidget and therefore needs a fifth App ID,
# profile, entitlement rule, and device acceptance record.

[[tasks]]
task_name = "LiveContainer"
app_name = "LiveContainer"
bundle_id = "io.example.livecontainer"
repo_url = "https://github.com/LiveContainer/LiveContainer"
release_glob = "LiveContainer.ipa"
slug = "LiveContainer"
publication_enabled = false

[tasks.signing]
id_strategy = "preserve-source-suffix"
unknown_profile_bundles = "error"
profile_type = "IOS_APP_DEVELOPMENT"

[tasks.signing.app_groups]
shared = "group.io.example.livecontainer"

[[tasks.signing.bundles]]
source_bundle_id = "com.kdt.livecontainer"
target_bundle_id = "io.example.livecontainer"
role = "root"
required_capabilities = ["APP_GROUPS", "HEALTHKIT", "INCREASED_MEMORY_LIMIT", "KEYCHAIN_SHARING", "CLINICAL_HEALTH_RECORDS", "HEALTHKIT_BACKGROUND_DELIVERY"]
entitlement_mode = "template"
entitlements_file = "configs/signing/livecontainer/root-process.plist"

[[tasks.signing.bundles]]
source_bundle_id = "com.kdt.livecontainer.LiveProcess"
required_capabilities = ["APP_GROUPS", "HEALTHKIT", "INCREASED_MEMORY_LIMIT", "KEYCHAIN_SHARING", "CLINICAL_HEALTH_RECORDS", "HEALTHKIT_BACKGROUND_DELIVERY"]
entitlement_mode = "template"
entitlements_file = "configs/signing/livecontainer/root-process.plist"

[[tasks.signing.bundles]]
source_bundle_id = "com.kdt.livecontainer.LaunchAppExtension"
required_capabilities = ["APP_GROUPS"]
entitlement_mode = "profile"

[[tasks.signing.bundles]]
source_bundle_id = "com.kdt.livecontainer.ShareExtension"
required_capabilities = ["APP_GROUPS"]
entitlement_mode = "profile"

# entitlement_mode values:
# - "profile": use the mapped profile's entitlement document.
# - "preserve-source": rewrite reviewed team/identifier/App Group values while
#   retaining the remaining source values; any drop must be declared.
# - "template": load a plist below configs/signing using only typed
#   ${TEAM_ID}, ${APP_IDENTIFIER_PREFIX}, ${TARGET_BUNDLE_ID}, and
#   ${APP_GROUP:<alias>} placeholders.
